---
import Layout from '../layouts/Layout.astro';
import SchemaMarkup from '../components/SchemaMarkup.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import StepsForm from '../components/StepsForm.astro';
import communes from '../data/communes.json';
import { generateCommuneContent, getDynamicPrices, getCommuneStaticData } from '../lib/contentEngine';
import { getSmartNearbyCommunes } from '../lib/geoLinks';

export async function getStaticPaths() {
  return communes.map((c) => ({
    params: { commune: c.slug },
    props: { commune: c },
  }));
}

const { commune } = Astro.props;
const pageType = 'refection';
const local = generateCommuneContent(commune, pageType);
const prices = getDynamicPrices(commune);
const data = getCommuneStaticData(commune);
const nearby = getSmartNearbyCommunes(commune.slug, communes, 6, 2);

const title = local.title;
const description = local.introParagraph.slice(0, 155);

const breadcrumbItems = [
  { label: "Accueil", href: "/" },
  { label: "Villes Alpes-Maritimes (06)", href: "/communes/" },
  { label: `Rénovation Toiture à ${commune.nom}` }
];

// Year for freshness
const year = new Date().getFullYear();
---

<Layout title={title} description={description}>
  <SchemaMarkup
    slot="head"
    pageUrl={Astro.url.href}
    pageTitle={title}
    pageDescription={description}
    faqItems={local.faqItems}
    breadcrumbItems={[
      { label: "Accueil", href: "/" },
      { label: "Villes Alpes-Maritimes", href: "/communes/" },
      { label: `Rénovation Toiture à ${commune.nom}` }
    ]}
    communeName={commune.nom}
    communeData={commune}
  />

  <Breadcrumb items={breadcrumbItems} />

  <!-- Hero Section -->
  <section style="background: linear-gradient(135deg, rgba(15,23,42,0.07) 0%, rgba(190,24,93,0.04) 100%); padding: 55px 0; border-bottom: 1.5px solid var(--border-color);">
    <div class="container">
      <div class="two-column-layout">
        <div style="display: flex; flex-direction: column; justify-content: center;">
          <div class="badge-pill" style="width: max-content; margin-bottom: 20px;">
            🏰 Rénovation Toiture — {commune.nom} ({commune.codePostal})
          </div>
          <h1 style="font-family: var(--font-heading); font-size: 38px; font-weight: 800; color: var(--primary); line-height: 1.2; margin-bottom: 20px;">
            Rénovation de Toiture à <span style="color: var(--secondary);">{commune.nom}</span> — Couvreur Expert 06
          </h1>
          <p style="font-size: 16.5px; line-height: 1.7; color: var(--text); margin-bottom: 25px;">
            {local.introParagraph}
          </p>

          <!-- Key data pills -->
          <div style="display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 25px;">
            <span style="background: var(--primary-light); border: 1px solid var(--border-color); padding: 6px 14px; border-radius: 20px; font-size: 13px; font-weight: 700; color: var(--primary);">
              📍 {data.altitudeZone} — alt. {data.altitude}m
            </span>
            <span style="background: var(--primary-light); border: 1px solid var(--border-color); padding: 6px 14px; border-radius: 20px; font-size: 13px; font-weight: 700; color: var(--primary);">
              👷 {data.rge} couvreurs RGE actifs
            </span>
            <span style="background: var(--primary-light); border: 1px solid var(--border-color); padding: 6px 14px; border-radius: 20px; font-size: 13px; font-weight: 700; color: var(--primary);">
              ⏱ Devis sous {data.delays} jours
            </span>
            <span style="background: var(--primary-light); border: 1px solid var(--border-color); padding: 6px 14px; border-radius: 20px; font-size: 13px; font-weight: 700; color: var(--primary);">
              🏗️ Zone vent : {data.windZone}
            </span>
          </div>

          <div style="background: white; border: 1.5px solid var(--border-color); border-left: 4px solid var(--secondary); padding: 18px; border-radius: var(--radius-sm); box-shadow: var(--shadow-sm);">
            <div style="font-weight: 750; color: var(--secondary); margin-bottom: 6px; font-size: 14px; text-transform: uppercase; letter-spacing: 0.05em;">💡 Conseil de Couvreur Local</div>
            <p style="font-size: 13.5px; color: var(--text-muted); margin: 0; line-height: 1.6;">
              {commune.conseilLocal}
            </p>
          </div>
        </div>

        <!-- Form -->
        <div>
          <StepsForm initialZip={commune.codePostal} initialCommune={commune.nom} />
        </div>
      </div>
    </div>
  </section>

  <!-- Local Data Authority Panel -->
  <section style="padding: 50px 0; background-color: var(--primary); color: white;">
    <div class="container">
      <div style="text-align: center; margin-bottom: 35px;">
        <h2 style="font-family: var(--font-heading); font-size: 26px; font-weight: 800; color: white; margin-bottom: 10px;">
          Données Techniques & Marché Toiture — {commune.nom} ({year})
        </h2>
        <p style="color: #94A3B8; font-size: 15px;">Indicateurs clés pour planifier votre rénovation de couverture dans les Alpes-Maritimes.</p>
      </div>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 25px; max-width: 1100px; margin: 0 auto;">
        <div style="text-align: center; padding: 20px; background: rgba(255,255,255,0.06); border-radius: var(--radius-sm); border: 1px solid rgba(255,255,255,0.12);">
          <div style="font-family: var(--font-mono); font-size: 28px; font-weight: 800; color: var(--secondary); margin-bottom: 6px;">{data.rPrice} €</div>
          <div style="font-size: 12.5px; color: #94A3B8; text-transform: uppercase; letter-spacing: 0.06em;">Prix moyen au m² (réfection)</div>
        </div>
        <div style="text-align: center; padding: 20px; background: rgba(255,255,255,0.06); border-radius: var(--radius-sm); border: 1px solid rgba(255,255,255,0.12);">
          <div style="font-family: var(--font-mono); font-size: 28px; font-weight: 800; color: var(--secondary); margin-bottom: 6px;">{data.rge}</div>
          <div style="font-size: 12.5px; color: #94A3B8; text-transform: uppercase; letter-spacing: 0.06em;">Artisans RGE locaux</div>
        </div>
        <div style="text-align: center; padding: 20px; background: rgba(255,255,255,0.06); border-radius: var(--radius-sm); border: 1px solid rgba(255,255,255,0.12);">
          <div style="font-family: var(--font-mono); font-size: 28px; font-weight: 800; color: var(--secondary); margin-bottom: 6px;">{commune.population.toLocaleString('fr-FR')}</div>
          <div style="font-size: 12.5px; color: #94A3B8; text-transform: uppercase; letter-spacing: 0.06em;">Habitants ({data.populationLabel})</div>
        </div>
        <div style="text-align: center; padding: 20px; background: rgba(255,255,255,0.06); border-radius: var(--radius-sm); border: 1px solid rgba(255,255,255,0.12);">
          <div style="font-family: var(--font-mono); font-size: 28px; font-weight: 800; color: var(--secondary); margin-bottom: 6px;">{data.delays}j</div>
          <div style="font-size: 12.5px; color: #94A3B8; text-transform: uppercase; letter-spacing: 0.06em;">Délai moyen devis</div>
        </div>
        <div style="text-align: center; padding: 20px; background: rgba(255,255,255,0.06); border-radius: var(--radius-sm); border: 1px solid rgba(255,255,255,0.12);">
          <div style="font-family: var(--font-mono); font-size: 28px; font-weight: 800; color: var(--secondary); margin-bottom: 6px;">{data.snowZone.split(' ')[0]}</div>
          <div style="font-size: 12.5px; color: #94A3B8; text-transform: uppercase; letter-spacing: 0.06em;">Zone neige réglementaire</div>
        </div>
        <div style="text-align: center; padding: 20px; background: rgba(255,255,255,0.06); border-radius: var(--radius-sm); border: 1px solid rgba(255,255,255,0.12);">
          <div style="font-family: var(--font-mono); font-size: 28px; font-weight: 800; color: var(--secondary); margin-bottom: 6px;">{data.rValueReq}</div>
          <div style="font-size: 12.5px; color: #94A3B8; text-transform: uppercase; letter-spacing: 0.06em;">R-value requis (isolation)</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Roof Characteristics + Technical Analysis -->
  <section style="padding: 70px 0; background-color: var(--card-bg);">
    <div class="container">
      <div style="text-align: center; max-width: 800px; margin: 0 auto 50px;">
        <h2 style="font-family: var(--font-heading); font-size: 32px; font-weight: 800; color: var(--primary); margin-bottom: 15px;">
          Analyse Technique des Toitures à {commune.nom}
        </h2>
        <p style="font-size: 16px; color: var(--text-muted);">
          Contraintes climatiques locales, architecture du bâti et règles techniques applicables à {commune.nom} ({commune.intercommunalite}).
        </p>
      </div>

      <div class="grid-3">
        <div class="card">
          <div style="font-size: 28px; margin-bottom: 12px;">🌡️</div>
          <h3 style="font-family: var(--font-heading); font-size: 18px; font-weight: 700; color: var(--primary); margin-bottom: 10px;">Contraintes Climatiques</h3>
          <p style="font-size: 14px; color: var(--text-muted); line-height: 1.65; margin: 0;">
            {local.climateContext}
          </p>
        </div>

        <div class="card">
          <div style="font-size: 28px; margin-bottom: 12px;">🏛️</div>
          <h3 style="font-family: var(--font-heading); font-size: 18px; font-weight: 700; color: var(--primary); margin-bottom: 10px;">Urbanisme & Règles ABF</h3>
          <p style="font-size: 14px; color: var(--text-muted); line-height: 1.65; margin: 0;">
            {local.abfRegulations}
          </p>
        </div>

        <div class="card">
          <div style="font-size: 28px; margin-bottom: 12px;">🏡</div>
          <h3 style="font-family: var(--font-heading); font-size: 18px; font-weight: 700; color: var(--primary); margin-bottom: 10px;">Parc Immobilier Local</h3>
          <p style="font-size: 14px; color: var(--text-muted); line-height: 1.65; margin: 0;">
            {local.housingTypologyInsight}
          </p>
        </div>
      </div>

      <!-- Roof Characteristics Detail -->
      {commune.roofCharacteristics && (
        <div style="margin-top: 50px; background: white; border: 1.5px solid var(--border-color); border-radius: var(--radius-sm); padding: 30px; box-shadow: var(--shadow-sm);">
          <h3 style="font-family: var(--font-heading); font-size: 20px; font-weight: 700; color: var(--primary); margin-bottom: 20px; display: flex; align-items: center; gap: 10px;">
            🔧 Caractéristiques Techniques Recommandées pour {commune.nom}
          </h3>
          <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 20px;">
            <div style="padding: 16px; background: var(--primary-light); border-radius: var(--radius-sm); border-left: 3px solid var(--secondary);">
              <div style="font-size: 12px; color: var(--text-muted); text-transform: uppercase; font-weight: 700; margin-bottom: 6px;">Tuile Dominante</div>
              <div style="font-size: 14.5px; color: var(--primary); font-weight: 700;">{commune.roofCharacteristics.tuileDominante}</div>
            </div>
            <div style="padding: 16px; background: var(--primary-light); border-radius: var(--radius-sm); border-left: 3px solid var(--secondary);">
              <div style="font-size: 12px; color: var(--text-muted); text-transform: uppercase; font-weight: 700; margin-bottom: 6px;">Fixation</div>
              <div style="font-size: 14.5px; color: var(--primary); font-weight: 700;">{commune.roofCharacteristics.fixation}</div>
            </div>
            <div style="padding: 16px; background: var(--primary-light); border-radius: var(--radius-sm); border-left: 3px solid var(--secondary);">
              <div style="font-size: 12px; color: var(--text-muted); text-transform: uppercase; font-weight: 700; margin-bottom: 6px;">Ventilation</div>
              <div style="font-size: 14.5px; color: var(--primary); font-weight: 700;">{commune.roofCharacteristics.ventilation}</div>
            </div>
            <div style="padding: 16px; background: var(--primary-light); border-radius: var(--radius-sm); border-left: 3px solid var(--secondary);">
              <div style="font-size: 12px; color: var(--text-muted); text-transform: uppercase; font-weight: 700; margin-bottom: 6px;">Écran Sous-Toiture</div>
              <div style="font-size: 14.5px; color: var(--primary); font-weight: 700;">{commune.roofCharacteristics.ecran}</div>
            </div>
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- Prices Table -->
  <section style="padding: 70px 0; background-color: #FAF9F6; border-top: 1.5px solid var(--border-color); border-bottom: 1.5px solid var(--border-color);">
    <div class="container">
      <div style="text-align: center; max-width: 800px; margin: 0 auto 45px;">
        <h2 style="font-family: var(--font-heading); font-size: 32px; font-weight: 800; color: var(--primary); margin-bottom: 12px;">
          Grille de Tarifs {year} — Couverture à {commune.nom}
        </h2>
        <p style="font-size: 15.5px; color: var(--text-muted);">
          Prix moyens TTC observés dans les Alpes-Maritimes par type de prestation. Valables pour le secteur de {commune.nom} ({commune.codePostal}).
        </p>
      </div>

      <div style="max-width: 900px; margin: 0 auto; overflow-x: auto; background: white; border: 1.5px solid var(--border-color); border-radius: var(--radius-sm); box-shadow: var(--shadow-sm);">
        <table style="width: 100%; border-collapse: collapse; text-align: left; font-size: 14.5px;">
          <thead>
            <tr style="background: var(--primary); color: white;">
              <th style="padding: 16px 20px; font-family: var(--font-heading); font-weight: 700;">Type de Travaux</th>
              <th style="padding: 16px 20px; font-family: var(--font-heading); font-weight: 700;">Fourchette {year}</th>
              <th style="padding: 16px 20px; font-family: var(--font-heading); font-weight: 700;">Unité</th>
              <th style="padding: 16px 20px; font-family: var(--font-heading); font-weight: 700;">Normes</th>
            </tr>
          </thead>
          <tbody>
            <tr style="border-bottom: 1px solid var(--border-color);">
              <td style="padding: 15px 20px; font-weight: bold; color: var(--primary);">Réfection tuiles plates Marseille + HPV</td>
              <td style="padding: 15px 20px;"><span class="price-tag">{prices.refectionMarseille.min} – {prices.refectionMarseille.max} €</span></td>
              <td style="padding: 15px 20px; color: var(--text-muted);">/ m²</td>
              <td style="padding: 15px 20px; color: var(--text-muted); font-size: 13px;">DTU 40.21 — NF EN 1304</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--border-color); background: var(--primary-light);">
              <td style="padding: 15px 20px; font-weight: bold; color: var(--primary);">Réfection tuiles canal traditionnelles</td>
              <td style="padding: 15px 20px;"><span class="price-tag">{prices.refectionCanal.min} – {prices.refectionCanal.max} €</span></td>
              <td style="padding: 15px 20px; color: var(--text-muted);">/ m²</td>
              <td style="padding: 15px 20px; color: var(--text-muted); font-size: 13px;">DTU 40.21 — NF EN 539-2</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--border-color);">
              <td style="padding: 15px 20px; font-weight: bold; color: var(--primary);">Démoussage + Hydrofuge perlant</td>
              <td style="padding: 15px 20px;"><span class="price-tag">{prices.demoussageHydro.min} – {prices.demoussageHydro.max} €</span></td>
              <td style="padding: 15px 20px; color: var(--text-muted);">/ m²</td>
              <td style="padding: 15px 20px; color: var(--text-muted); font-size: 13px;">Traitement doux (sans H.P.)</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--border-color); background: var(--primary-light);">
              <td style="padding: 15px 20px; font-weight: bold; color: var(--primary);">Réparation fuite urgente (orage)</td>
              <td style="padding: 15px 20px;"><span class="price-tag">{prices.reparationFuite.min} – {prices.reparationFuite.max} €</span></td>
              <td style="padding: 15px 20px; color: var(--text-muted);">/ intervention</td>
              <td style="padding: 15px 20px; color: var(--text-muted); font-size: 13px;">Urgence 24-48h</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--border-color);">
              <td style="padding: 15px 20px; font-weight: bold; color: var(--primary);">Gouttière cuivre ou inox 316L posée</td>
              <td style="padding: 15px 20px;"><span class="price-tag">{prices.zinguerieMl.min} – {prices.zinguerieMl.max} €</span></td>
              <td style="padding: 15px 20px; color: var(--text-muted);">/ m.l.</td>
              <td style="padding: 15px 20px; color: var(--text-muted); font-size: 13px;">NF EN 612 — DTU 40.5</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--border-color); background: var(--primary-light);">
              <td style="padding: 15px 20px; font-weight: bold; color: var(--primary);">Faîtage ventilé à sec (closoir alu)</td>
              <td style="padding: 15px 20px;"><span class="price-tag">{prices.faitageMl.min} – {prices.faitageMl.max} €</span></td>
              <td style="padding: 15px 20px; color: var(--text-muted);">/ m.l.</td>
              <td style="padding: 15px 20px; color: var(--text-muted); font-size: 13px;">DTU 40.21 §5.3</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--border-color);">
              <td style="padding: 15px 20px; font-weight: bold; color: var(--primary);">Isolation sarking (fibre de bois R≥6)</td>
              <td style="padding: 15px 20px;"><span class="price-tag">{prices.isolationSarking.min} – {prices.isolationSarking.max} €</span></td>
              <td style="padding: 15px 20px; color: var(--text-muted);">/ m² (aide RGE)</td>
              <td style="padding: 15px 20px; color: var(--text-muted); font-size: 13px;">CPT 3651 — RE2020</td>
            </tr>
            <tr style="background: var(--primary-light);">
              <td style="padding: 15px 20px; font-weight: bold; color: var(--primary);">Traitement charpente (insecticide/fongicide)</td>
              <td style="padding: 15px 20px;"><span class="price-tag">{prices.charpenteExotique.min} – {prices.charpenteExotique.max} €</span></td>
              <td style="padding: 15px 20px; color: var(--text-muted);">/ m²</td>
              <td style="padding: 15px 20px; color: var(--text-muted); font-size: 13px;">Arr. 27/06/2011</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p style="text-align: center; margin-top: 18px; font-size: 12.5px; color: var(--text-muted);">
        * Prix indicatifs TTC pour le secteur de {commune.nom}. Les tarifs définitifs dépendent de la surface, de la pente, de l'accessibilité et des contraintes ABF locales. Valable {year}.
      </p>
      <div style="text-align: center; margin-top: 30px;">
        <a href="/devis/" class="btn-primary" style="display: inline-block;">📋 Obtenir une Estimation Gratuite &rarr;</a>
      </div>
    </div>
  </section>

  <!-- Energy & Real Estate Section -->
  <section style="padding: 70px 0; background-color: var(--card-bg);">
    <div class="container" style="max-width: 950px;">
      <div style="text-align: center; margin-bottom: 40px;">
        <h2 style="font-family: var(--font-heading); font-size: 30px; font-weight: 800; color: var(--primary); margin-bottom: 12px;">
          Isolation & Valorisation Immobilière à {commune.nom}
        </h2>
      </div>

      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 25px;">
        <div style="background: white; border: 1.5px solid var(--border-color); border-radius: var(--radius-sm); padding: 28px; box-shadow: var(--shadow-sm);">
          <div style="font-size: 32px; margin-bottom: 14px;">🔥</div>
          <h3 style="font-family: var(--font-heading); font-size: 18px; font-weight: 700; color: var(--primary); margin-bottom: 10px;">Économies d'Énergie</h3>
          <p style="font-size: 14px; color: var(--text-muted); line-height: 1.65; margin-bottom: 15px;">
            {local.energyProfileText}
          </p>
          <div style="background: var(--primary-light); border-radius: var(--radius-sm); padding: 14px; font-size: 13px; color: var(--primary); font-weight: 700;">
            🎯 Isolation obligatoire : R ≥ {data.rValueReq} pour les aides MaPrimeRénov' {year}
          </div>
        </div>
        <div style="background: white; border: 1.5px solid var(--border-color); border-radius: var(--radius-sm); padding: 28px; box-shadow: var(--shadow-sm);">
          <div style="font-size: 32px; margin-bottom: 14px;">📈</div>
          <h3 style="font-family: var(--font-heading); font-size: 18px; font-weight: 700; color: var(--primary); margin-bottom: 10px;">Plus-Value Immobilière</h3>
          <p style="font-size: 14px; color: var(--text-muted); line-height: 1.65; margin-bottom: 15px;">
            {local.realEstateInsight}
          </p>
          <div style="background: var(--primary-light); border-radius: var(--radius-sm); padding: 14px; font-size: 13px; color: var(--primary); font-weight: 700;">
            🏠 Marché : {commune.intercommunalite}
          </div>
        </div>
      </div>

      <!-- Financial Aid Box -->
      <div style="margin-top: 30px; background: linear-gradient(135deg, #0F172A 0%, #1e293b 100%); color: white; border-radius: var(--radius-sm); padding: 30px;">
        <h3 style="font-family: var(--font-heading); font-size: 20px; font-weight: 700; color: white; margin-bottom: 18px;">💰 Aides Financières disponibles à {commune.nom} en {year}</h3>
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 15px; margin-bottom: 20px;">
          <div style="background: rgba(255,255,255,0.08); padding: 14px; border-radius: 8px;">
            <div style="color: var(--secondary); font-weight: 700; font-size: 14px; margin-bottom: 4px;">MaPrimeRénov'</div>
            <div style="color: #CBD5E1; font-size: 13px;">Jusqu'à 75 € / m² (ménages modestes)</div>
          </div>
          <div style="background: rgba(255,255,255,0.08); padding: 14px; border-radius: 8px;">
            <div style="color: var(--secondary); font-weight: 700; font-size: 14px; margin-bottom: 4px;">CEE (Primes Énergie)</div>
            <div style="color: #CBD5E1; font-size: 13px;">10 à 20 € / m² supplémentaires</div>
          </div>
          <div style="background: rgba(255,255,255,0.08); padding: 14px; border-radius: 8px;">
            <div style="color: var(--secondary); font-weight: 700; font-size: 14px; margin-bottom: 4px;">TVA 5,5 %</div>
            <div style="color: #CBD5E1; font-size: 13px;">Sur travaux d'isolation + tuiles</div>
          </div>
          <div style="background: rgba(255,255,255,0.08); padding: 14px; border-radius: 8px;">
            <div style="color: var(--secondary); font-weight: 700; font-size: 14px; margin-bottom: 4px;">Éco-PTZ</div>
            <div style="color: #CBD5E1; font-size: 13px;">Prêt à 0 % jusqu'à 30 000 €</div>
          </div>
        </div>
