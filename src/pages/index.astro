---
import Layout from '../layouts/Layout.astro';
import SchemaMarkup from '../components/SchemaMarkup.astro';
import StepsForm from '../components/StepsForm.astro';
import communes from '../data/communes.json';

const title = "Rénovation de Toiture dans les Alpes-Maritimes (06) | Devis Gratuits & Couvreur Premium";
const description = "Rénovation de toiture de standing, étanchéité de toit terrasse et traitement hydrofuge de tuiles dans les Alpes-Maritimes (06). Recevez 3 devis gratuits.";

// Select the top 12 cities for homepage list
const popularCities = communes.slice(0, 12);
---

<Layout title={title} description={description}>
  <SchemaMarkup
    slot="head"
    pageUrl={Astro.url.href}
    pageTitle={title}
    pageDescription={description}
    faqItems={[
      {
        q: "Quel est le prix au m² pour refaire son toit dans les Alpes-Maritimes ?",
        a: "Le tarif moyen pour une réfection de toiture en tuiles plates Marseille oscille entre 140€ et 220€ le m² TTC. Pour des tuiles canal traditionnelles posées à l'ancienne, comptez entre 130€ et 200€ le m² TTC, pose comprise."
      },
      {
        q: "Pourquoi utiliser de la zinguerie cuivre ou inox sur le littoral du 06 ?",
        a: "L'air marin et les embruns salins corrodent le zinc standard en moins de 8 ans. L'inox 316L (qualité marine) ou le cuivre développent une résistance naturelle à l'oxydation marine, assurant une longévité supérieure à 50 ans."
      },
      {
        q: "Quelles sont les aides pour isoler sa toiture de villa à Nice ou Cannes ?",
        a: "Les travaux d'isolation thermique par l'extérieur (Sarking) ou sous rampants réalisés par un artisan certifié RGE du 06 ouvrent droit à MaPrimeRénov', aux primes CEE locales, à l'éco-PTZ et à une TVA réduite à 5,5%."
      }
    ]}
  />

  <!-- Hero Section -->
  <section class="hero">
    <div class="container">
      <div class="two-column-layout">
        <!-- Hero Left Info -->
        <div>
          <div class="alert-pill">
            <div class="alert-pulse-icon"></div>
            <span>Expertise villa premium — devis sous 24h</span>
          </div>
          <h1>
            Votre Toiture d'Exception dans les Alpes-Maritimes (06)
          </h1>
          <p>
            Soleil intense de la Côte d'Azur, orages d'automne diluviens et embruns salins corrosifs... Vos toitures de villas azuréennes nécessitent des matériaux haut de gamme (cuivre, inox, tuile plate de Marseille, membrane PVC-P) et un savoir-faire certifié RGE. Comparez 3 devis d'artisans qualifiés assurés en décennale.
          </p>
          
          <div style="display: flex; gap: 20px; margin-top: 10px; flex-wrap: wrap;">
            <div style="background: rgba(255, 255, 255, 0.08); border: 1.5px solid rgba(255, 255, 255, 0.15); padding: 12px 20px; border-radius: var(--radius-sm);">
              <span style="font-size: 20px; margin-right: 8px;">🛡️</span>
              <strong style="color: white; font-size: 14.5px;">Garantie Décennale 10 ans</strong>
            </div>
            <div style="background: rgba(255, 255, 255, 0.08); border: 1.5px solid rgba(255, 255, 255, 0.15); padding: 12px 20px; border-radius: var(--radius-sm);">
              <span style="font-size: 20px; margin-right: 8px;">🏆</span>
              <strong style="color: white; font-size: 14.5px;">Artisans RGE &amp; ABF Compatibles</strong>
            </div>
          </div>
        </div>

        <!-- Hero Right Form -->
        <div>
          <StepsForm />
        </div>
      </div>
    </div>
  </section>

  <!-- Regional Context Section -->
  <section style="padding: 75px 0; background-color: var(--card-bg);">
    <div class="container">
      <div style="text-align: center; max-width: 800px; margin: 0 auto 50px;">
        <span class="badge-pill" style="margin-bottom: 15px;">🌊 Résister au Climat Azuréen</span>
        <h2 style="font-family: var(--font-heading); font-size: 32px; font-weight: 800; color: var(--primary); margin-bottom: 15px;">
          Pourquoi la toiture des Alpes-Maritimes exige des techniques premium ?
        </h2>
        <p style="font-size: 16.5px; color: var(--text-muted); line-height: 1.6;">
          Le département du 06 combine un ensoleillement intense de plus de 2800 heures par an avec l'agression saline des embruns sur le littoral et de violents orages de transition en automne.
        </p>
      </div>

      <div class="two-column-layout" style="align-items: stretch; gap: 40px;">
        <!-- Left: Weather challenges cards -->
        <div style="display: flex; flex-direction: column; gap: 20px;">
          <div class="card" style="border-left: 4px solid var(--secondary); border-top: none; display: flex; gap: 15px; padding: 20px; align-items: start;">
            <div style="font-size: 28px; line-height: 1;">🧂</div>
            <div>
              <h3 style="font-family: var(--font-heading); font-size: 17px; font-weight: 700; color: var(--primary); margin-bottom: 6px;">Corrosion Saline Littorale</h3>
              <p style="font-size: 13.5px; color: var(--text-muted); line-height: 1.5; margin: 0;">
                Les embruns marins corrodent le zinc standard en moins de 8 ans à Cannes ou Nice. Les toitures durables imposent de la zinguerie en cuivre ou en inox 316L et des crochets de tuiles inox.
              </p>
            </div>
          </div>

          <div class="card" style="border-left: 4px solid var(--secondary); border-top: none; display: flex; gap: 15px; padding: 20px; align-items: start;">
            <div style="font-size: 28px; line-height: 1;">☀️</div>
            <div>
              <h3 style="font-family: var(--font-heading); font-size: 17px; font-weight: 700; color: var(--primary); margin-bottom: 6px;">Surchauffe &amp; Rayonnement Solaire</h3>
              <p style="font-size: 13.5px; color: var(--text-muted); line-height: 1.5; margin: 0;">
                Le soleil de plomb surchauffe les combles à plus de 65°C en été. L'isolation par sarking en fibre de bois de haute densité permet de bloquer la chaleur et de réduire l'usage de la climatisation.
              </p>
            </div>
          </div>

          <div class="card" style="border-left: 4px solid var(--secondary); border-top: none; display: flex; gap: 15px; padding: 20px; align-items: start;">
            <div style="font-size: 28px; line-height: 1;">⚡</div>
            <div>
              <h3 style="font-family: var(--font-heading); font-size: 17px; font-weight: 700; color: var(--primary); margin-bottom: 6px;">Orages Azuréens Violents</h3>
              <p style="font-size: 13.5px; color: var(--text-muted); line-height: 1.5; margin: 0;">
                Les épisodes pluvieux d'automne déversent d'importantes quantités d'eau en peu de temps. Des noues larges, des gouttières de grand développement et un écran sous-toiture HPV préviennent les infiltrations.
              </p>
            </div>
          </div>
        </div>

        <!-- Right: Illustrative image -->
        <div style="border-radius: var(--radius-md); overflow: hidden; border: 1.5px solid var(--border-color); box-shadow: var(--shadow-sm); display: flex; flex-direction: column;">
          <img 
            src="/images/hero-toiture-alpes-maritimes.png" 
            alt="Magnifique toiture en tuiles neuves sur une villa de standing sur la Côte d'Azur" 
            style="width: 100%; height: 100%; object-fit: cover; min-height: 350px;" 
            loading="lazy"
          />
          <div style="padding: 12px 18px; background: white; border-top: 1.5px solid var(--border-color); font-size: 12.5px; color: var(--text-muted); font-family: var(--font-mono);">
            🏡 Villa azuréenne typique à flanc de colline avec couverture neuve en tuiles plates scellées.
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Materials Guide Section -->
  <section style="padding: 75px 0; background-color: #FAF9F6; border-top: 1.5px solid var(--border-color); border-bottom: 1.5px solid var(--border-color);">
    <div class="container">
      <div style="text-align: center; max-width: 800px; margin: 0 auto 50px;">
        <h2 style="font-family: var(--font-heading); font-size: 32px; font-weight: 800; color: var(--primary); margin-bottom: 15px;">
          Tuile de Marseille vs Tuile Canal : Quelle Couverture Choisir ?
        </h2>
        <p style="font-size: 16px; color: var(--text-muted);">
          Le standard géométrique à emboîtement ou l'authenticité historique des bastides.
        </p>
      </div>

      <div class="two-column-layout" style="gap: 40px; align-items: stretch;">
        <!-- Marseille -->
        <div style="background: white; border: 1.5px solid var(--border-color); border-radius: var(--radius-md); box-shadow: var(--shadow-sm); overflow: hidden; display: flex; flex-direction: column;">
          <img src="/images/guide-tuile-plate-marseille.png" alt="Tuiles plates de Marseille en terre cuite ocre sur toit azuréen" style="width: 100%; height: 200px; object-fit: cover; border-bottom: 1.5px solid var(--border-color);" loading="lazy" />
          <div style="padding: 30px; display: flex; flex-direction: column; height: 100%;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px; flex-wrap: wrap; gap: 10px;">
              <h3 style="font-family: var(--font-heading); font-size: 20px; font-weight: 700; color: var(--primary); margin: 0;">La Tuile Plate de Marseille</h3>
              <span class="badge-pill" style="background: var(--primary-light); color: var(--primary); margin: 0; font-size: 11px;">Le Standard Mécanique</span>
            </div>
            <p style="font-size: 14px; color: var(--text-muted); line-height: 1.5; margin-bottom: 20px; flex-grow: 1;">
              La tuile plate de Marseille est le choix moderne par excellence pour la majorité des maisons des collines azuréennes et des copropriétés de Nice et Cannes. Son système de double emboîtement garantit une étanchéité parfaite face au vent littoral fort.
            </p>
            <ul style="padding-left: 20px; font-size: 13px; color: var(--text); display: flex; flex-direction: column; gap: 8px; margin: 0;">
              <li><strong>Sécurité au vent :</strong> Verrouillage par emboîtement réduisant le risque d'arrachement.</li>
              <li><strong>Poids modéré :</strong> Sollicite moins la charpente que la tuile canal traditionnelle.</li>
              <li><strong>Économie :</strong> Pose simplifiée et plus rapide, réduisant le coût de main-d'œuvre.</li>
            </ul>
          </div>
        </div>

        <!-- Canal -->
        <div style="background: white; border: 1.5px solid var(--border-color); border-radius: var(--radius-md); box-shadow: var(--shadow-sm); overflow: hidden; display: flex; flex-direction: column;">
          <img src="/images/guide-budget-cote-d-azur.png" alt="Toits anciens en tuile canal de Grasse ou Menton" style="width: 100%; height: 200px; object-fit: cover; border-bottom: 1.5px solid var(--border-color);" loading="lazy" />
          <div style="padding: 30px; display: flex; flex-direction: column; height: 100%;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px; flex-wrap: wrap; gap: 10px;">
              <h3 style="font-family: var(--font-heading); font-size: 20px; font-weight: 700; color: var(--primary); margin: 0;">La Tuile Canal Traditionnelle</h3>
              <span class="badge-pill" style="background: #FFF5F7; color: var(--secondary); border-color: var(--secondary); margin: 0; font-size: 11px;">Le Charme Historique</span>
            </div>
            <p style="font-size: 14px; color: var(--text-muted); line-height: 1.5; margin-bottom: 20px; flex-grow: 1;">
              Indispensable pour la restauration des villas Belle Époque, des bastides provençales de Grasse et de Vence, ou du Vieux-Nice. Posée de façon traditionnelle au mortier de chaux avec des génoises maçonnées.
            </p>
            <ul style="padding-left: 20px; font-size: 13px; color: var(--text); display: flex; flex-direction: column; gap: 8px; margin: 0;">
              <li><strong>Esthétique provençale :</strong> Restitue le cachet historique des toitures d'époque.</li>
              <li><strong>Inertie thermique :</strong> Épaisseur importante offrant une excellente isolation solaire passive.</li>
              <li><strong>ABF Conforme :</strong> Généralement obligatoire dans les zones classées historiques.</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Interactive Budget Estimator Section (Vanilla JS) -->
  <section style="padding: 75px 0; background-color: var(--card-bg);">
    <div class="container" style="max-width: 800px;">
      <div style="text-align: center; margin-bottom: 40px;">
        <span class="badge-pill" style="margin-bottom: 15px;">🧮 Estimateur de Budget Virtuel</span>
        <h2 style="font-family: var(--font-heading); font-size: 32px; font-weight: 800; color: var(--primary); margin-bottom: 15px;">
          Estimer le Tarif Moyen de mes Travaux de Toiture (06)
        </h2>
        <p style="font-size: 16px; color: var(--text-muted);">
          Sélectionnez la surface de votre toiture et le type de travaux pour simuler votre coût moyen.
        </p>
      </div>

      <div style="background: white; border: 1.5px solid var(--border-color); border-radius: var(--radius-sm); padding: 35px; box-shadow: var(--shadow-lg);">
        <div style="display: flex; flex-direction: column; gap: 20px;">
          <!-- Field 1: Work Type -->
          <div class="form-group">
            <label style="font-family: var(--font-heading); font-weight: bold; font-size: 16px;">Type de Projet :</label>
            <select id="estimator-type" class="form-control" style="background: white; font-weight: bold;">
              <option value="romane">🔨 Rénovation complète Tuiles Plates Marseille (avec écran HPV)</option>
              <option value="canal">🔨 Rénovation complète Tuiles Canal traditionnelles</option>
              <option value="demoussage">🧼 Nettoyage &amp; Traitement Hydrofuge imperméable</option>
              <option value="zinc">⚡ Couverture en Zinc / Cuivre / Inox étamé sur-mesure</option>
            </select>
          </div>

          <!-- Field 2: Surface Slider -->
          <div class="form-group">
            <div style="display: flex; justify-content: space-between; font-weight: bold; margin-bottom: 8px;">
              <label style="font-family: var(--font-heading); font-size: 16px; margin: 0;">Surface de la toiture :</label>
              <span style="color: var(--secondary); font-family: var(--font-mono);"><span id="estimator-surface-val">100</span> m²</span>
            </div>
            <input type="range" id="estimator-surface" min="40" max="300" step="10" value="100" style="width: 100%; accent-color: var(--secondary); cursor: pointer;" />
            <div style="display: flex; justify-content: space-between; font-size: 11px; color: var(--text-muted); margin-top: 5px;">
              <span>40 m²</span>
              <span>150 m²</span>
              <span>300 m²</span>
            </div>
          </div>

          <!-- Field 3: Heights option -->
          <div class="form-group">
            <label style="font-family: var(--font-heading); font-weight: bold; font-size: 16px;">Hauteur du bâtiment :</label>
            <div style="display: flex; gap: 15px; margin-top: 5px;">
              <label style="font-size: 14.5px; display: flex; align-items: center; gap: 8px; cursor: pointer;">
                <input type="radio" name="estimator-height" value="1" checked style="accent-color: var(--secondary);" /> Plain-pied (RDC)
              </label>
              <label style="font-size: 14.5px; display: flex; align-items: center; gap: 8px; cursor: pointer;">
                <input type="radio" name="estimator-height" value="1.25" style="accent-color: var(--secondary);" /> À étage (R+1 ou R+2)
              </label>
            </div>
          </div>

          <!-- Divider -->
          <hr style="border: 0; border-top: 1.5px solid var(--border-color); margin: 10px 0;" />

          <!-- Output Pricing Box -->
          <div style="background: var(--primary-light); border: 2.5px dashed var(--border-color); padding: 25px; border-radius: var(--radius-sm); display: flex; flex-direction: column; align-items: center; gap: 10px;">
            <div style="font-size: 13.5px; color: var(--primary); font-weight: bold; text-transform: uppercase; letter-spacing: 0.5px;">Estimation budgétaire 2026 :</div>
            <div style="font-size: 32px; font-weight: 800; color: var(--secondary); font-family: var(--font-mono);" id="estimator-result">
              14 000 € – 22 000 €
            </div>
            <p style="font-size: 12.5px; color: var(--text-muted); text-align: center; margin: 0;">
              Cette estimation inclut la fourniture des matériaux de qualité et la pose par un artisan assuré avec garantie décennale dans les Alpes-Maritimes. Hors subventions RGE.
            </p>
          </div>

          <div style="text-align: center; margin-top: 10px;">
            <a href="#devis" class="btn-primary" style="display: inline-block;">📋 Recevoir mes 3 Devis Fermes &amp; Gratuits &rarr;</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Popular Cities Link Directory -->
  <section style="padding: 75px 0; background-color: var(--bg); border-top: 1.5px solid var(--border-color);">
    <div class="container">
      <div style="text-align: center; max-width: 800px; margin: 0 auto 40px;">
        <span class="badge-pill" style="margin-bottom: 15px;">🗺️ Interventions de Proximité</span>
        <h2 style="font-family: var(--font-heading); font-size: 32px; font-weight: 800; color: var(--primary);">
          Villes principales d'intervention dans les Alpes-Maritimes
        </h2>
        <p style="font-size: 16px; color: var(--text-muted); margin-top: 10px;">
          Retrouvez nos couvreurs partenaires actifs sur votre secteur de résidence du 06.
        </p>
      </div>

      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 20px;">
        {popularCities.map((c) => (
          <div style="background: white; border: 1.5px solid var(--border-color); border-radius: var(--radius-sm); padding: 20px; box-shadow: var(--shadow-sm); display: flex; flex-direction: column; justify-content: space-between;">
            <h3 style="font-family: var(--font-heading); font-size: 18px; font-weight: 700; color: var(--text); margin-bottom: 12px;">
              🏰 Couvreur {c.nom} ({c.codePostal})
            </h3>
            <div style="display: flex; flex-direction: column; gap: 6px; font-size: 13px;">
              <a href={`/renovation-toiture-${c.slug}/`} style="color: var(--primary); font-weight: bold;">🔨 Rénovation &amp; Couverture &rarr;</a>
              <a href={`/toiture-villa-${c.slug}/`} style="color: var(--primary); font-weight: bold;">🧼 Villa Premium &rarr;</a>
              <a href={`/expert-couverture-${c.slug}/`} style="color: var(--primary); font-weight: bold;">👤 Couvreur Certifié RGE &rarr;</a>
            </div>
          </div>
        ))}
      </div>
      
      <div style="text-align: center; margin-top: 40px;">
        <a href="/communes/" class="btn-secondary" style="display: inline-block;">🗺️ Voir toutes les communes des Alpes-Maritimes &rarr;</a>
      </div>
    </div>
  </section>

  <!-- Estimator Script logic -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const typeSelect = document.getElementById('estimator-type') as HTMLSelectElement;
      const surfaceSlider = document.getElementById('estimator-surface') as HTMLInputElement;
      const surfaceVal = document.getElementById('estimator-surface-val');
      const heightRadios = document.getElementsByName('estimator-height') as NodeListOf<HTMLInputElement>;
      const resultDiv = document.getElementById('estimator-result');

      const calculate = () => {
        if (!typeSelect || !surfaceSlider || !resultDiv) return;

        const type = typeSelect.value;
        const surface = Number(surfaceSlider.value);
        if (surfaceVal) surfaceVal.textContent = surface.toString();

        let multiplier = 1;
        for (const radio of heightRadios) {
          if ((radio as HTMLInputElement).checked) {
            multiplier = Number((radio as HTMLInputElement).value);
            break;
          }
        }

        let minPriceM2 = 140;
        let maxPriceM2 = 220;

        if (type === 'canal') {
          minPriceM2 = 130;
          maxPriceM2 = 200;
        } else if (type === 'demoussage') {
          minPriceM2 = 20;
          maxPriceM2 = 40;
        } else if (type === 'zinc') {
          minPriceM2 = 120;
          maxPriceM2 = 250;
        }

        const calculatedMin = Math.round(surface * minPriceM2 * multiplier);
        const calculatedMax = Math.round(surface * maxPriceM2 * multiplier);

        // Format outputs
        const minStr = calculatedMin.toLocaleString('fr-FR') + ' €';
        const maxStr = calculatedMax.toLocaleString('fr-FR') + ' €';

        resultDiv.textContent = `${minStr} – ${maxStr}`;
      };

      typeSelect?.addEventListener('change', calculate);
      surfaceSlider?.addEventListener('input', calculate);
      heightRadios.forEach(radio => radio.addEventListener('change', calculate));

      // Initial calculation
      calculate();
    });
  </script>
</Layout>
