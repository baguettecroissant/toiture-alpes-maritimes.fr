---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import StepsForm from '../components/StepsForm.astro';

const title = "Tarifs Toiture dans les Alpes-Maritimes (06) en 2026 | Prix au m² Couvreur";
const description = "Retrouvez la grille de prix détaillée pour vos travaux de toiture dans les Alpes-Maritimes (06). Prix de réfection tuile plate/canal, étanchéité terrasse, sarking.";

const breadcrumbItems = [
  { label: "Accueil", href: "/" },
  { label: "Tarifs Toiture 2026" }
];
---

<Layout title={title} description={description}>
  <Breadcrumb items={breadcrumbItems} />

  <section style="padding: 50px 0 80px; background-color: var(--card-bg);">
    <div class="container">
      <div style="text-align: center; max-width: 800px; margin: 0 auto 50px;">
        <span class="badge-pill" style="margin-bottom: 15px;">📊 Guide Tarifaire Officiel 2026</span>
        <h1 style="font-family: var(--font-heading); font-size: 36px; font-weight: 800; color: var(--primary); margin-bottom: 15px;">
          Quel est le Prix au m² d'un Couvreur dans les Alpes-Maritimes ?
        </h1>
        <p style="font-size: 16.5px; color: var(--text-muted); line-height: 1.6;">
          Les tarifs de toiture dépendent fortement du matériau choisi (tuile de Marseille mécanique, tuile canal scellée à la chaux, étanchéité synthétique EPDM/PVC) et de la hauteur du bâtiment. Voici les coûts moyens constatés sur le 06.
        </p>
      </div>

      <div class="two-column-layout" style="align-items: start;">
        <!-- Left: Table & Details -->
        <div>
          <div style="border-radius: var(--radius-md); overflow: hidden; border: 1.5px solid var(--border-color); box-shadow: var(--shadow-sm); margin-bottom: 25px;">
            <img src="/images/guide-budget-cote-d-azur.png" alt="Vue aérienne des toits de Nice ou Cannes en tuiles plates et canal" style="width: 100%; height: 240px; object-fit: cover;" />
          </div>

          <div style="overflow-x: auto; background: white; border: 2px solid var(--border-color); border-radius: var(--radius-md); box-shadow: var(--shadow-sm); margin-bottom: 35px;">
            <table style="width: 100%; border-collapse: collapse; text-align: left; font-size: 14.5px;">
              <thead>
                <tr style="background: var(--primary); color: white;">
                  <th style="padding: 16px 20px; font-family: var(--font-heading); font-weight: 700;">Type de Travaux</th>
                  <th style="padding: 16px 20px; font-family: var(--font-heading); font-weight: 700;">Prix Moyen 2026</th>
                  <th style="padding: 16px 20px; font-family: var(--font-heading); font-weight: 700;">Unité</th>
                </tr>
              </thead>
              <tbody>
                <tr style="border-bottom: 1px solid var(--border-color);">
                  <td style="padding: 16px 20px; font-weight: bold; color: var(--primary);">Réfection tuiles plates Marseille (HPV compris)</td>
                  <td style="padding: 16px 20px;"><span class="price-tag">140 – 220 €</span></td>
                  <td style="padding: 16px 20px; color: var(--text-muted);">au m²</td>
                </tr>
                <tr style="border-bottom: 1px solid var(--border-color); background: var(--primary-light);">
                  <td style="padding: 16px 20px; font-weight: bold; color: var(--primary);">Réfection tuiles canal traditionnelles</td>
                  <td style="padding: 16px 20px;"><span class="price-tag">130 – 200 €</span></td>
                  <td style="padding: 16px 20px; color: var(--text-muted);">au m²</td>
                </tr>
                <tr style="border-bottom: 1px solid var(--border-color);">
                  <td style="padding: 16px 20px; font-weight: bold; color: var(--primary);">Étanchéité Toiture Terrasse PVC-P / EPDM</td>
                  <td style="padding: 16px 20px;"><span class="price-tag">70 – 130 €</span></td>
                  <td style="padding: 16px 20px; color: var(--text-muted);">au m²</td>
                </tr>
                <tr style="border-bottom: 1px solid var(--border-color); background: var(--primary-light);">
                  <td style="padding: 16px 20px; font-weight: bold; color: var(--primary);">Toiture terrasse végétalisée (substrat + sédum)</td>
                  <td style="padding: 16px 20px;"><span class="price-tag">100 – 180 €</span></td>
                  <td style="padding: 16px 20px; color: var(--text-muted);">au m²</td>
                </tr>
                <tr style="border-bottom: 1px solid var(--border-color);">
                  <td style="padding: 16px 20px; font-weight: bold; color: var(--primary);">Nettoyage hydrofuge complet perlant</td>
                  <td style="padding: 16px 20px;"><span class="price-tag">20 – 40 €</span></td>
                  <td style="padding: 16px 20px; color: var(--text-muted);">au m²</td>
                </tr>
                <tr style="border-bottom: 1px solid var(--border-color); background: var(--primary-light);">
                  <td style="padding: 16px 20px; font-weight: bold; color: var(--primary);">Réparation de fuite d'urgence (infiltration)</td>
                  <td style="padding: 16px 20px;"><span class="price-tag">400 – 2 000 €</span></td>
                  <td style="padding: 16px 20px; color: var(--text-muted);">par diagnostic</td>
                </tr>
                <tr style="border-bottom: 1px solid var(--border-color);">
                  <td style="padding: 16px 20px; font-weight: bold; color: var(--primary);">Gouttières Cuivre / Inox 316L (embruns)</td>
                  <td style="padding: 16px 20px;"><span class="price-tag">80 – 150 €</span></td>
                  <td style="padding: 16px 20px; color: var(--text-muted);">par mètre linéaire</td>
                </tr>
                <tr style="border-bottom: 1px solid var(--border-color); background: var(--primary-light);">
                  <td style="padding: 16px 20px; font-weight: bold; color: var(--primary);">Isolation thermique sarking (fibre de bois R>=6)</td>
                  <td style="padding: 16px 20px;"><span class="price-tag">110 – 190 €</span></td>
                  <td style="padding: 16px 20px; color: var(--text-muted);">au m²</td>
                </tr>
                <tr style="border-bottom: 1px solid var(--border-color);">
                  <td style="padding: 16px 20px; font-weight: bold; color: var(--primary);">Charpente en bois de standing (Red Cedar / Iroko)</td>
                  <td style="padding: 16px 20px;"><span class="price-tag">100 – 180 €</span></td>
                  <td style="padding: 16px 20px; color: var(--text-muted);">au m²</td>
                </tr>
              </tbody>
            </table>
          </div>

          <div style="background: white; border: 1.5px solid var(--border-color); border-radius: var(--radius-sm); padding: 25px; box-shadow: var(--shadow-sm);">
            <h3 style="font-family: var(--font-heading); font-size: 18px; font-weight: 700; color: var(--primary); margin-bottom: 12px;">📈 Subventions &amp; Dispositifs Énergétiques 06</h3>
            <p style="font-size: 14.5px; color: var(--text-muted); line-height: 1.6; margin-bottom: 15px;">
              Les chantiers de rénovation de toiture et d'isolation de villas sur la Riviera bénéficient de soutiens financiers majeurs :
            </p>
            <ul style="padding-left: 20px; font-size: 14px; color: var(--text); display: flex; flex-direction: column; gap: 8px;">
              <li><strong>TVA réduite à 5,5% :</strong> Applicable aux travaux d'isolation thermique (sarking, rampants) si l'artisan est certifié RGE.</li>
              <li><strong>TVA à 10% :</strong> Applicable aux travaux de réfection de couverture simple (changement de tuiles de Marseille, étanchéité terrasse, zinguerie, démoussage) pour les logements construits depuis plus de 2 ans.</li>
              <li><strong>MaPrimeRénov' &amp; CEE :</strong> Subventions de l'ANAH et primes éco-énergie régionales PACA cumulables pour minimiser le reste à charge de votre isolation de toit.</li>
            </ul>
          </div>
        </div>

        <!-- Right: Form -->
        <div>
          <StepsForm />
        </div>
      </div>
    </div>
  </section>
</Layout>
